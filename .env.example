# Скопируйте этот файл в .env и заполните реальными значениями.
# .env никогда не должен попадать в git (см. .gitignore) — там секреты.

# Магазины Ozon — по одному блоку SHOP_N_* на каждый магазин, нумерация с 1
# без пропусков (SHOP_1_*, SHOP_2_*, ...). Бот сам подхватит все блоки по
# порядку, пока не встретит пропущенный номер. Ключи — в кабинете каждого
# магазина: Настройки → Seller API → «Сгенерировать ключ» (роль read-only
# недостаточна — боту нужно право на печать этикеток).
SHOP_1_NAME=Магазин 1
SHOP_1_CLIENT_ID=
SHOP_1_API_KEY=

SHOP_2_NAME=Магазин 2
SHOP_2_CLIENT_ID=
SHOP_2_API_KEY=

# Если магазин один — просто удалите блок SHOP_2_*.
# Если магазинов больше двух — добавьте SHOP_3_*, SHOP_4_* и т.д.

# Токен бота от @BotFather в Telegram.
BOT_TOKEN=

# Ваш личный chat_id в Telegram. Не знаете — впишите сюда что угодно,
# запустите бота, напишите ему /start в личку — он в ответ покажет
# ваш настоящий chat_id, впишите его сюда и перезапустите бота.
CHAT_ID=

# Доп. люди — полноправные админы наравне с CHAT_ID: получают те же
# уведомления/этикетки И могут точно так же управлять ботом (команды,
# кнопки, /merge и т.д., каждый свою сессию). Через запятую, если получателей
# несколько: EXTRA_CHAT_IDS=111111,222222
# Как узнать chat_id доп. человека: пусть он напишет боту в личку что угодно
# (пока его нет в списке — бот проигнорирует, но chat_id появится в логах
# сервера: journalctl -u ozon-bot | grep "постороннего chat_id").
# EXTRA_CHAT_IDS=

# Необязательные настройки (можно не трогать — сработают значения по умолчанию):
# POLL_SECONDS=90
# POSTING_LOOKBACK_DAYS=3
# MAX_OFFER_IDS_ON_LABEL=4
# HEARTBEAT_SECONDS=21600
# AUTO_RESTART_SECONDS=3600

# Прокси только для api.telegram.org — нужен, если хостинг блокирует
# исходящий TCP/443 к Telegram (частый случай для VPS в РФ, см. DEPLOY.md).
# Ozon-запросы прокси не используют. Пусто = прямое подключение.
# TELEGRAM_PROXY=socks5h://user:password@host:port
